# 🛡️ Warranty Fraud Detector - Environment Variables

# Google Gemini API Key (Get one from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative: GOOGLE_API_KEY=your_google_api_key_here

# Database Configuration (Defaults to local SQLite db if unset)
# DATABASE_URL=postgresql://user:password@localhost/warranty_db

# Risk Engine Thresholds (Optional)
# RISK_APPROVE_THRESHOLD=20
# RISK_REVIEW_THRESHOLD=50
